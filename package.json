{
  "name": "seapedia-comfest18",
  "version": "3.0.0",
  "description": "SEAPEDIA COMPFEST 18 marketplace challenge with Express.js backend and Vue.js frontend",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "backend:start": "node server.js",
    "frontend:dev": "npm run dev --prefix frontend",
